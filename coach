#!/bin/bash
# Run the chess coach. Long-term memory (self-hosted Supermemory) is the
# heart of this coach, so this launcher GUARANTEES it: if the server on
# localhost:6767 isn't running it is started automatically, and if memory
# can't be enabled the coach refuses to run rather than silently forget.
#
#   ./coach YOUR_CHESSCOM_USERNAME [--chat] [--months N] ...
set -euo pipefail
cd "$(dirname "$0")"

[ -x venv/bin/python ] || { echo "Run ./install.sh first." >&2; exit 1; }

SM_PORT=6767
MEMORY_MODEL="llama3.2:3b"

server_up() { lsof -iTCP:$SM_PORT -sTCP:LISTEN >/dev/null 2>&1; }

if [ -z "${SUPERMEMORY_API_KEY:-}" ]; then
    if ! server_up; then
        SM_BIN="$(command -v supermemory-server || true)"
        [ -z "$SM_BIN" ] && [ -x "$HOME/.local/bin/supermemory-server" ] \
            && SM_BIN="$HOME/.local/bin/supermemory-server"
        [ -n "$SM_BIN" ] || { echo "supermemory-server not installed — run ./install.sh first." >&2; exit 1; }
        echo "Memory server not running — starting it …"
        mkdir -p .supermemory
        OPENAI_BASE_URL=http://localhost:11434/v1 OPENAI_API_KEY=ollama \
            MODEL="$MEMORY_MODEL" nohup "$SM_BIN" >> .supermemory/server.log 2>&1 &
        for _ in $(seq 1 60); do
            server_up && [ -f .supermemory/api-key ] && break
            sleep 1
        done
    fi
    server_up || { echo "Memory server failed to start — see .supermemory/server.log" >&2; exit 1; }
    KEY_FILE=.supermemory/api-key
    if [ ! -f "$KEY_FILE" ]; then
        # Server was started from another directory (e.g. a second checkout):
        # find its working dir via its PID and use the key it keeps there.
        SM_PID="$(lsof -tiTCP:$SM_PORT -sTCP:LISTEN 2>/dev/null | head -1)"
        SM_CWD="$(lsof -a -p "$SM_PID" -d cwd -Fn 2>/dev/null | sed -n 's/^n//p' | head -1)"
        [ -n "$SM_CWD" ] && [ -f "$SM_CWD/.supermemory/api-key" ] && KEY_FILE="$SM_CWD/.supermemory/api-key"
    fi
    [ -f "$KEY_FILE" ] \
        || { echo "Memory server is up on :${SM_PORT} but its API key can't be found — restart it from this directory (kill it, then re-run ./coach) or export SUPERMEMORY_API_KEY." >&2; exit 1; }
    export SUPERMEMORY_API_KEY="$(cat "$KEY_FILE")"
    export SUPERMEMORY_BASE_URL="http://localhost:${SM_PORT}"
fi

exec venv/bin/python -m chesscoach "$@"
